# LLM gateway — required. All Claude calls route through OpenRouter.
OPENROUTER_API_KEY=

# Optional: helps OpenRouter dashboard tag traffic from this deployment.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=TTB Label Verifier

# Sentry — required for production deploys. Wizard fills these in.
SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
